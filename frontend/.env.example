# Copy to .env.local and edit, or set in Vercel project settings.
#
# Backend URL. Leave empty in development — the Vite proxy in vite.config.js
# forwards /api/* to http://127.0.0.1:8000 automatically. In production, set
# this to the Railway backend URL, e.g.:
#   VITE_API_BASE_URL=https://gencode-backend.up.railway.app
VITE_API_BASE_URL=
