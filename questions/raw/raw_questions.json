    "id": "P014",
    "primary_kp_label": "arithmetic operators in python",
    "statement": "Write a function power(base, exp) that returns base raised to the power of exp using a loop (not the ** operator or built-in pow function). The exponent is always a non-negative integer.",
    "function_signature": "power(base, exp)",
    "sample_tests": [
      {"input": "2, 3", "expected": "8"},
      {"input": "5, 0", "expected": "1"},
      {"input": "3, 4", "expected": "81"},
      {"input": "10, 2", "expected": "100"}
    ],
    "hidden_tests": [
      {"input": "0, 0", "expected": "1", "edge_label": "zero_to_zero"},
      {"input": "0, 5", "expected": "0", "edge_label": "zero_base"},
      {"input": "1, 100", "expected": "1", "edge_label": "one_base_large_exp"},
      {"input": "2, 10", "expected": "1024", "edge_label": "large_exponent"}
    ],
    "reference_solution": "def power(base, exp):\n    result = 1\n    for _ in range(exp):\n        result *= base\n    return result"
