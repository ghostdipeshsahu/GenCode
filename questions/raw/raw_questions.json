  {
    "id": "P015",
    "primary_kp_label": "conditional statements in python",
    "statement": "Write a function bmi_category(weight_kg, height_m) that returns the BMI category as a string. BMI = weight / height^2. Categories: below 18.5 is 'Underweight', 18.5 to 24.9 is 'Normal', 25 to 29.9 is 'Overweight', 30 and above is 'Obese'.",
    "function_signature": "bmi_category(weight_kg, height_m)",
    "sample_tests": [
      {"input": "50, 1.7", "expected": "'Underweight'"},
      {"input": "70, 1.75", "expected": "'Normal'"},
      {"input": "85, 1.75", "expected": "'Overweight'"},
      {"input": "100, 1.75", "expected": "'Obese'"}
    ],
    "hidden_tests": [
      {"input": "46.7, 1.6", "expected": "'Underweight'", "edge_label": "boundary_underweight"},
      {"input": "47.5, 1.6", "expected": "'Normal'", "edge_label": "boundary_normal_low"},
      {"input": "64.0, 1.6", "expected": "'Normal'", "edge_label": "boundary_normal_high"},
      {"input": "64.1, 1.6", "expected": "'Overweight'", "edge_label": "boundary_overweight"},
      {"input": "76.9, 1.6", "expected": "'Obese'", "edge_label": "boundary_obese"}
    ],
    "reference_solution": "def bmi_category(weight_kg, height_m):\n    bmi = weight_kg / (height_m ** 2)\n    if bmi < 18.5:\n        return 'Underweight'\n    elif bmi < 25:\n        return 'Normal'\n    elif bmi < 30:\n        return 'Overweight'\n    else:\n        return 'Obese'"
  }
