    "primary_kp_label": "string methods in python",
    "statement": "Write a function is_anagram(word1, word2) that returns True if word1 and word2 are anagrams of each other (contain the same letters in any order, case-insensitive), and False otherwise.",
    "function_signature": "is_anagram(word1, word2)",
    "sample_tests": [
      {"input": "'listen', 'silent'", "expected": "True"},
      {"input": "'hello', 'world'", "expected": "False"},
      {"input": "'Triangle', 'Integral'", "expected": "True"},
      {"input": "'abc', 'cab'", "expected": "True"}
    ],
    "hidden_tests": [
      {"input": "'', ''", "expected": "True", "edge_label": "both_empty"},
      {"input": "'a', 'a'", "expected": "True", "edge_label": "single_char_same"},
      {"input": "'abc', 'abcd'", "expected": "False", "edge_label": "different_lengths"},
      {"input": "'Astronomer', 'Moon starer'", "expected": "False", "edge_label": "with_spaces"}
    ],
    "reference_solution": "def is_anagram(word1, word2):\n    return sorted(word1.lower()) == sorted(word2.lower())"
